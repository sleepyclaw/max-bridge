# Bridge server port (default: 7734)
BRIDGE_PORT=7734

# Shared secret for authentication
BRIDGE_TOKEN=replace-me

# OpenClaw target recipient/session identifier
OPENCLAW_TARGET=replace-with-your-target

# Optional override if OpenClaw is not in PATH
# OPENCLAW_BIN=openclaw

# Optional request timeout in ms
# REQUEST_TIMEOUT=120000

# Optional owner name suppression for forwarded text decoration
# OWNER_NAME=
